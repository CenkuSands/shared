# ==========================================
# Configuration Variables
# ==========================================
$pat = "YOUR_PERSONAL_ACCESS_TOKEN_HERE"

$sourceCollectionUrl = "http://your-server:8080/tfs/SourceCollection"
$sourceProject = "SourceProjectName"

$targetCollectionUrl = "http://your-server:8080/tfs/TargetCollection"
$targetProject = "TargetProjectName"

$apiVersion = "api-version=6.0"

# Create the Authentication Header
$encodedPat = [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes(":$pat"))
$headers = @{
    Authorization = "Basic $encodedPat"
    "Content-Type" = "application/json-patch+json" # Required for Work Item Creation
}

# ==========================================
# Step 1: Query Source for Work Items (WIQL)
# ==========================================
Write-Host "Querying source project for work items..." -ForegroundColor Cyan

# Simple WIQL: Get all Tasks in the source project
$wiqlQuery = @{
    query = "SELECT [System.Id] FROM WorkItems WHERE [System.TeamProject] = '$sourceProject' AND [System.WorkItemType] = 'Task'"
} | ConvertTo-Json

$wiqlUrl = "$sourceCollectionUrl/_apis/wit/wiql?$apiVersion"
$wiqlResponse = Invoke-RestMethod -Uri $wiqlUrl -Method Post -Body $wiqlQuery -Headers @{ Authorization = "Basic $encodedPat"; "Content-Type" = "application/json" }

$workItemIds = $wiqlResponse.workItems.id
Write-Host "Found $($workItemIds.Count) work items to migrate." -ForegroundColor Green


# Create a dictionary to map Old IDs to New IDs (Crucial for Pass 2 Link Reconstruction)
$idMap = @{} 

# ==========================================
# Step 2 & 3: Extract and Recreate
# ==========================================
foreach ($id in $workItemIds) {
    
    # --- Step 2: Get Source Item Details ---
    $sourceItemUrl = "$sourceCollectionUrl/_apis/wit/workitems/$id`?$apiVersion"
    $sourceItem = Invoke-RestMethod -Uri $sourceItemUrl -Method Get -Headers @{ Authorization = "Basic $encodedPat" }
    
    # Extract the type and remove any hidden trailing spaces
    $type = $sourceItem.fields.'System.WorkItemType'.Trim()
    
    # WORK ITEM TYPE MAPPING:
    # If your target project uses a different Process Template (e.g., Basic instead of Agile),
    # map the types here to avoid 404 Not Found errors. 
    # If both projects are Agile, you can just leave this as is, the 'default' will catch it.
    switch ($type) {
        "Bug"         { $targetType = "Issue" } # Maps Agile 'Bug' to Basic 'Issue'
        "Feature"     { $targetType = "Epic" }  # Maps Agile 'Feature' to Basic 'Epic'
        "User Story"  { $targetType = "Issue" } # Maps Agile 'User Story' to Basic 'Issue'
        default       { $targetType = $type }   # Keeps the type exactly the same
    }

    # Safely encode the target type for the URL (converts "User Story" to "User%20Story")
    $safeType = [uri]::EscapeDataString($targetType)

    # Extract all possible text fields
    $title = $sourceItem.fields.'System.Title'
    $description = $sourceItem.fields.'System.Description'
    $reproSteps = $sourceItem.fields.'Microsoft.VSTS.TCM.ReproSteps'
    $systemInfo = $sourceItem.fields.'Microsoft.VSTS.TCM.SystemInfo'
    $acceptanceCriteria = $sourceItem.fields.'Microsoft.VSTS.Common.AcceptanceCriteria'
    
    Write-Host "Migrating ID $id : $title (Source: $type -> Target: $targetType)"

    # --- Step 3: Create Target Item (JSON Patch) ---
    $patchOperations = @()

    # Dynamically build the payload. Only add operations for fields that actually exist.
    if (![string]::IsNullOrWhiteSpace($title)) {
        $patchOperations += @{ op = "add"; path = "/fields/System.Title"; value = $title }
    }

    if (![string]::IsNullOrWhiteSpace($description)) {
        $patchOperations += @{ op = "add"; path = "/fields/System.Description"; value = $description }
    }

    if (![string]::IsNullOrWhiteSpace($reproSteps)) {
        $patchOperations += @{ op = "add"; path = "/fields/Microsoft.VSTS.TCM.ReproSteps"; value = $reproSteps }
    }

    if (![string]::IsNullOrWhiteSpace($systemInfo)) {
        $patchOperations += @{ op = "add"; path = "/fields/Microsoft.VSTS.TCM.SystemInfo"; value = $systemInfo }
    }

    if (![string]::IsNullOrWhiteSpace($acceptanceCriteria)) {
        $patchOperations += @{ op = "add"; path = "/fields/Microsoft.VSTS.Common.AcceptanceCriteria"; value = $acceptanceCriteria }
    }

    # Convert to JSON using -InputObject to enforce the required JSON Array [ ] format
    $patchDocument = ConvertTo-Json -InputObject $patchOperations -Depth 10
    
    # Build the creation URL
    $createUrl = "$targetCollectionUrl/$targetProject/_apis/wit/workitems/`$$safeType`?bypassRules=true&$apiVersion"

    try {
        # Create the item in the target collection
        $targetItem = Invoke-RestMethod -Uri $createUrl -Method Post -Body $patchDocument -Headers $headers
        Write-Host "  -> Successfully created new ID: $($targetItem.id) in target project." -ForegroundColor Green
        
        # Save the ID mapping so Pass 2 (Link Reconstruction) knows where to point the links
        $idMap[$id] = $targetItem.id
    }
    catch {
        Write-Host "  -> Failed to create item $id." -ForegroundColor Red
        Write-Host "     HTTP Status: $($_.Exception.Message)" -ForegroundColor DarkRed
        
        # Raw error extraction for deep debugging (catches 404s, 500s, etc.)
        if ($_.Exception.Response) {
            $reader = New-Object System.IO.StreamReader($_.Exception.Response.GetResponseStream())
            $rawResponse = $reader.ReadToEnd()
            
            Write-Host "     Raw Server Output:" -ForegroundColor Yellow
            Write-Host "     $rawResponse" -ForegroundColor DarkGray
        }
    }
}

# ==========================================
# Phase 4: Reconstruct Links (Pass 2)
# ==========================================
Write-Host "Starting Pass 2: Reconstructing Relationships..." -ForegroundColor Cyan

foreach ($oldId in $workItemIds) {
    
    # BULLETPROOF URL: Using string concatenation to protect the $expand variable
    $sourceItemUrl = "$sourceCollectionUrl/_apis/wit/workitems/$oldId" + '?$expand=relations&' + $apiVersion
    
    try {
        $sourceItem = Invoke-RestMethod -Uri $sourceItemUrl -Method Get -Headers @{ Authorization = "Basic $encodedPat" }
    } catch {
        Write-Host "  -> Failed to GET source item $oldId. Error: $($_.Exception.Message)" -ForegroundColor Red
        continue # Skip to the next item if this one fails
    }
    
    if ($sourceItem.relations) {
        
        $newSourceId = $idMap[$oldId]
        $linkOperations = @()

        foreach ($relation in $sourceItem.relations) {
            if ($relation.rel -match "System.LinkTypes") {
                
                $oldTargetId = [regex]::Match($relation.url, '\d+$').Value
                $newTargetId = $idMap[[int]$oldTargetId]

                if ($newTargetId) {
                    $newTargetUrl = "$targetCollectionUrl/_apis/wit/workitems/$newTargetId"
                    
                    $linkOperations += @{
                        op = "add"
                        path = "/relations/-" 
                        value = @{
                            rel = $relation.rel 
                            url = $newTargetUrl
                        }
                    }
                }
            }
        }

        if ($linkOperations.Count -gt 0) {
            $linkPatchDocument = ConvertTo-Json -InputObject $linkOperations -Depth 10
            
            # BULLETPROOF URL: Safe concatenation for the PATCH request
            $updateUrl = "$targetCollectionUrl/$targetProject/_apis/wit/workitems/$newSourceId?" + $apiVersion

            try {
                Invoke-RestMethod -Uri $updateUrl -Method Patch -Body $linkPatchDocument -Headers $headers | Out-Null
                Write-Host "  -> Successfully rebuilt links for New ID: $newSourceId" -ForegroundColor Green
            }
            catch {
                Write-Host "  -> Failed to rebuild links for New ID: $newSourceId." -ForegroundColor Red
                
                if ($_.Exception.Response) {
                    $reader = New-Object System.IO.StreamReader($_.Exception.Response.GetResponseStream())
                    $rawResponse = $reader.ReadToEnd()
                    Write-Host "     Raw Server Output: $rawResponse" -ForegroundColor DarkGray
                }
            }
        }
    }
}

Write-Host "Migration and Link Reconstruction Complete!" -ForegroundColor Cyan
