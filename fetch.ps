# ==========================================
# Configuration Variables
# ==========================================
$pat = "YOUR_PERSONAL_ACCESS_TOKEN_HERE"
$sourceCollectionUrl = "https://your-server:8080/tfs/SourceCollection"
$project = "YourProjectName"
$apiVersion = "api-version=6.0"

$targetFilePath = "/azure-pipelines.yml"
$searchString = "windows-latest" 

# --- NEW: Define the specific branch to search ---
$targetBranch = "feature/my-specific-branch"

$encodedPat = [Convert]::ToBase64String([Text.Encoding]::ASCII.GetBytes(":$pat"))
$headers = @{ Authorization = "Basic $encodedPat" }

# ==========================================
# Step 1: Get All Repositories
# ==========================================
Write-Host "Fetching list of all repositories..." -ForegroundColor Cyan
$reposUrl = "$sourceCollectionUrl/$project/_apis/git/repositories?$apiVersion"
$reposResponse = Invoke-RestMethod -Uri $reposUrl -Method Get -Headers $headers
$repositories = $reposResponse.value
Write-Host "Found $($repositories.Count) repositories. Scanning branch '$targetBranch'..." -ForegroundColor Green
Write-Host "---------------------------------------------------"

# ==========================================
# Step 2: Loop Through Repos & Search Content
# ==========================================
# ==========================================
# Step 2: Loop Through Repos & Search Content
# ==========================================
foreach ($repo in $repositories) {
    $repoName = $repo.name
    $repoId = $repo.id
    
    # THE FIX: Using string concatenation to safely add &$format=text
    # This forces ADO to return pure text instead of a JSON object.
    $itemUrl = "$sourceCollectionUrl/$project/_apis/git/repositories/$repoId/items" + '?path=' + $targetFilePath + '&versionDescriptor.version=' + $targetBranch + '&versionDescriptor.versionType=branch&$format=text&' + $apiVersion
    
    try {
        # Because we used $format=text, the response IS the raw file content
        $fileContent = Invoke-RestMethod -Uri $itemUrl -Method Get -Headers $headers
        
        # --- DEBUG CHECK ---
        # If the file is actually empty (or ADO refused to send the text), flag it!
        if ([string]::IsNullOrWhiteSpace($fileContent)) {
            Write-Host "[EMPTY FILE]   : $repoName (File was found, but it downloaded completely blank)" -ForegroundColor Magenta
            continue # Skip to the next repo
        }

        # Split the raw text into individual lines
        $lines = $fileContent -split "`n"
        $isMatch = $false
        
        foreach ($line in $lines) {
            # Strip whitespace and check for a match
            if ($line.Trim() -match [regex]::Escape($searchString.Trim())) {
                $isMatch = $true
                break 
            }
        }

        if ($isMatch) {
            Write-Host "[MATCH FOUND]  : $repoName" -ForegroundColor Green
        } else {
            Write-Host "[NO MATCH]     : $repoName (File downloaded, but string not found)" -ForegroundColor Yellow
        }
        
    } catch {
        $errorMessage = $_.Exception.Message
        
        if ($errorMessage -match "404") {
            Write-Host "[NOT FOUND]    : $repoName (Either branch '$targetBranch' or file '$targetFilePath' does not exist here)" -ForegroundColor DarkGray
        } else {
            Write-Host "[ERROR]        : $repoName ($errorMessage)" -ForegroundColor Red
        }
    }
}
